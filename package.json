{
  "name": "cordial-treasury-browser-wallet-extension",
  "description": "Silent crosschain browser wallet connecting to a Cordial Treasury deployment",
  "private": true,
  "version": "0.1.0",
  "version_name": "0.1.0-alpha1",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chromium": "wxt -b chromium",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "typecheck": "tsc -b && tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@noble/hashes": "^2.0.1",
    "@scure/base": "^2.0.0",
    "@serenity-kit/noble-sodium": "^0.2.2",
    "@solana/wallet-standard-features": "^1.3.0",
    "@wallet-standard/base": "^1.1.0",
    "@wallet-standard/features": "^1.1.0",
    "bignumber.js": "^9.3.1",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "idb-keyval": "^6.2.2",
    "prettier": "3.7.4",
    "superjson": "^2.2.6",
    "temporal-polyfill": "^0.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.51.0",
    "wxt": "^0.20.13",
    "zod": "^4.3.5"
  },
  "dependencies": {
    "jose": "^6.1.3"
  }
}
