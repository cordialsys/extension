{
  "name": "Cordial Browser Extension",
  "description": "Silent crosschain browser wallet connecting to a Cordial Treasury deployment",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:chromium": "wxt -b chromium",
    "dev:edge": "wxt -b edge",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "postinstall": "wxt prepare",
    "typecheck": "tsc -b && tsc --noEmit"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@scure/base": "^2.0.0",
    "@serenity-kit/noble-sodium": "^0.2.2",
    "@tsconfig/svelte": "^5.0.6",
    "@wxt-dev/module-svelte": "^2.0.4",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "idb-keyval": "^6.2.2",
    "prettier": "3.7.4",
    "svelte": "^5.46.0",
    "svelte-check": "^4.3.5",
    "temporal-polyfill": "^0.3.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1",
    "wxt": "^0.20.13"
  }
}
